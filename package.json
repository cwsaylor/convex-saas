{
  "name": "convex-saas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "vite",
    "dev:backend": "convex dev",
    "predev": "convex dev --run init --until-success",
    "build": "tsc -b && vite build",
    "lint": "eslint . --ignore-pattern convex/_generated --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json && tsc -p convex/tsconfig.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.92",
    "@convex-dev/react-query": "^0.1.0",
    "@epic-web/client-hints": "^1.3.2",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@react-email/components": "^1.0.12",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-query": "^5.51.15",
    "@tanstack/react-router": "^1.168.26",
    "class-variance-authority": "^0.7.0",
    "convex": "^1.13.2",
    "convex-helpers": "^0.1.50",
    "cookie": "^1.1.1",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.0.0",
    "i18next-http-backend": "^3.0.6",
    "lucide-react": "^1.14.0",
    "npm-run-all": "^4.1.5",
    "oslo": "^1.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.6",
    "resend": "^6.12.2",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/router-plugin": "^1.167.29",
    "@types/eslint__js": "^8.42.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "postcss": "^8.4.40",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10"
  }
}
